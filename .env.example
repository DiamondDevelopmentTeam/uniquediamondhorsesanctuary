# Paste the public URL for the Zeffy donation campaign.
VITE_ZEFFY_DONATION_URL=https://www.zeffy.com/en-US/donation-form/your-campaign

# Optional: use the Zeffy embed URL if you want the form shown inside the donation page.
VITE_ZEFFY_EMBED_URL=

# Existing sanctuary Zeffy shop. Replace if the campaign changes.
VITE_ZEFFY_SHOP_URL=https://www.zeffy.com/en-US/ticketing/unique-diamond-horse-sanctuarys-shop

# Optional POST endpoint for the contact/visit request form (Formspree, serverless function, etc.).
# When blank, the form opens an email draft to info@uniquediamondhorsesanctuary.org.
VITE_CONTACT_FORM_ENDPOINT=
